{
  "name": "polinko-dev",
  "image": "python:3.14-slim-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [8000, 5173, 8020],
  "postCreateCommand": "bash ./tools/setup_devcontainer.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python3",
        "python.createEnvironment.contentButton": "hide",
        "python.testing.pytestEnabled": false,
        "python.testing.unittestEnabled": true,
        "python.testing.unittestArgs": ["-s", "tests", "-p", "test_*.py"],
        "python.analysis.extraPaths": ["${workspaceFolder}"],
        "python.analysis.exclude": [
          "**/.history/**",
          "**/.venv/**",
          "**/node_modules/**",
          "**/apps/portfolio/node_modules/**"
        ],
        "ruff.importStrategy": "fromEnvironment",
        "ruff.path": ["${containerWorkspaceFolder}/.venv/bin/ruff"],
        "ruff.format.preview": true,
        "mypy-type-checker.importStrategy": "fromEnvironment",
        "mypy-type-checker.reportingScope": "workspace",
        "mypy-type-checker.cwd": "${containerWorkspaceFolder}",
        "mypy-type-checker.path": [
          "${containerWorkspaceFolder}/.venv/bin/python",
          "-m",
          "mypy"
        ],
        "mypy-type-checker.interpreter": [
          "${containerWorkspaceFolder}/.venv/bin/python3"
        ],
        "mypy-type-checker.args": ["--config-file", "mypy.ini"],
        "mypy-type-checker.showNotifications": "onError",
        "markdownlint.run": "onSave",
        "markdownlint.severityForError": "Warning",
        "markdownlint.ignore": [
          "**/docs/peanut/**",
          "**/.local/**",
          "**/output/**",
          "**/node_modules/**"
        ],
        "remote.extensionKind": {
          "ms-azuretools.vscode-docker": ["ui"]
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "window.commandCenter": true,
        "window.titleBarStyle": "custom",
        "window.customTitleBarVisibility": "auto"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "DavidAnson.vscode-markdownlint",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "openai.chatgpt",
        "mikestead.dotenv",
        "qwtel.sqlite-viewer"
      ]
    }
  },
  "remoteUser": "root"
}
