# Required: OpenAI key
OPENAI_API_KEY=your-key

# Optional: protect API endpoints with x-api-key header
POLINKO_SERVER_API_KEY=your-server-key
# Optional: key ring for multiple principals (JSON object)
# POLINKO_SERVER_API_KEYS_JSON={"team-a":"team-a-key","team-b":"team-b-key"}

# Optional: ChatKit UI workflow (required for ChatKit frontend session tokens)
# POLINKO_CHATKIT_WORKFLOW_ID=wkf_...
# POLINKO_CHATKIT_WORKFLOW_VERSION=1

# Optional runtime settings
POLINKO_MEMORY_DB_PATH=.polinko_memory.db
POLINKO_HISTORY_DB_PATH=.polinko_history.db
POLINKO_DEFAULT_SESSION_ID=default
POLINKO_LOG_LEVEL=INFO
POLINKO_RATE_LIMIT_PER_MINUTE=30
# Tuning mode: true = reset deprecates old chat, false = reset clears in-place
POLINKO_DEPRECATE_ON_RESET=true
# OCR provider: scaffold (default) or openai
POLINKO_OCR_PROVIDER=scaffold
# Used when POLINKO_OCR_PROVIDER=openai
POLINKO_OCR_MODEL=gpt-4.1-mini
POLINKO_OCR_PROMPT=Extract all readable text from this image. Return only extracted text and preserve line breaks.

# Optional vector-memory retrieval (cross-chat tuning memory)
POLINKO_VECTOR_ENABLED=false
POLINKO_VECTOR_DB_PATH=.polinko_vector.db
POLINKO_VECTOR_EMBEDDING_MODEL=text-embedding-3-small
POLINKO_VECTOR_TOP_K=2
POLINKO_VECTOR_MIN_SIMILARITY=0.40
POLINKO_VECTOR_MAX_CHARS=220
POLINKO_VECTOR_EXCLUDE_CURRENT_SESSION=true

# Optional: Responses API orchestration with file-search RAG
POLINKO_RESPONSES_ORCHESTRATION_ENABLED=false
POLINKO_RESPONSES_MODEL=gpt-5-chat-latest
# Required only when POLINKO_RESPONSES_ORCHESTRATION_ENABLED=true
POLINKO_RESPONSES_VECTOR_STORE_ID=
POLINKO_RESPONSES_INCLUDE_WEB_SEARCH=false
POLINKO_RESPONSES_HISTORY_TURN_LIMIT=12

# Optional: model-enforced structured extraction (OCR/PDF response normalization)
POLINKO_EXTRACTION_STRUCTURED_ENABLED=false
POLINKO_EXTRACTION_STRUCTURED_MODEL=gpt-4.1-mini

# Optional governance / guardrails
POLINKO_GOVERNANCE_ENABLED=true
POLINKO_GOVERNANCE_ALLOW_WEB_SEARCH=false
POLINKO_GOVERNANCE_LOG_ONLY=false
POLINKO_HALLUCINATION_GUARDRAILS_ENABLED=true
# Personalization default for retrieval memory scope: session or global
POLINKO_PERSONALIZATION_DEFAULT_MEMORY_SCOPE=global

# Optional CLI session name
POLINKO_CLI_SESSION_ID=polinko-cli
