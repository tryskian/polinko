# Required: OpenAI key
OPENAI_API_KEY=your-key

# Phase-2 migration: runtime now prefers `NAUTORUS_*` keys.
# Backward compatibility remains for legacy `POLINKO_*` keys.

# Optional: protect API endpoints with x-api-key header
NAUTORUS_SERVER_API_KEY=your-server-key
# Optional: key ring for multiple principals (JSON object)
# NAUTORUS_SERVER_API_KEYS_JSON={"team-a":"team-a-key","team-b":"team-b-key"}

# Optional: ChatKit UI workflow (required for ChatKit frontend session tokens)
# NAUTORUS_CHATKIT_WORKFLOW_ID=wkf_...
# NAUTORUS_CHATKIT_WORKFLOW_VERSION=1

# Optional runtime settings
NAUTORUS_MEMORY_DB_PATH=.polinko_memory.db
NAUTORUS_HISTORY_DB_PATH=.polinko_history.db
NAUTORUS_DEFAULT_SESSION_ID=default
NAUTORUS_LOG_LEVEL=INFO
NAUTORUS_RATE_LIMIT_PER_MINUTE=30
# Tuning mode: true = reset deprecates old chat, false = reset clears in-place
NAUTORUS_DEPRECATE_ON_RESET=true
# OCR provider: scaffold (default) or openai
NAUTORUS_OCR_PROVIDER=scaffold
# Used when NAUTORUS_OCR_PROVIDER=openai
NAUTORUS_OCR_MODEL=gpt-4.1-mini
NAUTORUS_OCR_PROMPT=Extract all readable text from this image. Preserve line breaks and symbols exactly. Do not invent letters or words; if uncertain, output [?].
# Convert speculative OCR guesses (for example "x or y", "likely ...") to `[?]`
NAUTORUS_OCR_UNCERTAINTY_SAFE=true
# Optional: visual-scene extraction for image retrieval memory (best-effort)
NAUTORUS_IMAGE_CONTEXT_ENABLED=false
NAUTORUS_IMAGE_CONTEXT_MODEL=gpt-4.1-mini
NAUTORUS_IMAGE_CONTEXT_PROMPT=Summarize the visual scene for retrieval: key entities, visible text cues, layout, and notable attributes. Keep it concise, factual, and grounded in what is visible.

# Optional vector-memory retrieval (cross-chat tuning memory)
NAUTORUS_VECTOR_ENABLED=false
NAUTORUS_VECTOR_DB_PATH=.polinko_vector.db
NAUTORUS_VECTOR_EMBEDDING_MODEL=text-embedding-3-small
NAUTORUS_VECTOR_TOP_K=2
# Optional per-scope retrieval overrides (fallback to NAUTORUS_VECTOR_TOP_K)
NAUTORUS_VECTOR_TOP_K_GLOBAL=2
NAUTORUS_VECTOR_TOP_K_SESSION=2
NAUTORUS_VECTOR_MIN_SIMILARITY=0.40
# Optional per-scope retrieval overrides (fallback to NAUTORUS_VECTOR_MIN_SIMILARITY)
NAUTORUS_VECTOR_MIN_SIMILARITY_GLOBAL=0.40
NAUTORUS_VECTOR_MIN_SIMILARITY_SESSION=0.40
NAUTORUS_VECTOR_MAX_CHARS=220
NAUTORUS_VECTOR_EXCLUDE_CURRENT_SESSION=true
# Optional: fall back to local deterministic embeddings on transient OpenAI
# connectivity/server failures (keeps evals stable; defaults false in runtime)
NAUTORUS_VECTOR_LOCAL_EMBEDDING_FALLBACK=false

# Optional: Responses API orchestration with file-search RAG
NAUTORUS_RESPONSES_ORCHESTRATION_ENABLED=false
NAUTORUS_RESPONSES_MODEL=gpt-5-chat-latest
# Required only when NAUTORUS_RESPONSES_ORCHESTRATION_ENABLED=true
NAUTORUS_RESPONSES_VECTOR_STORE_ID=
NAUTORUS_RESPONSES_INCLUDE_WEB_SEARCH=false
NAUTORUS_RESPONSES_HISTORY_TURN_LIMIT=12
# Optional: best-effort PDF indexing into OpenAI Responses vector store
NAUTORUS_RESPONSES_PDF_INGEST_ENABLED=false

# Optional: model-enforced structured extraction (OCR/PDF response normalization)
NAUTORUS_EXTRACTION_STRUCTURED_ENABLED=false
NAUTORUS_EXTRACTION_STRUCTURED_MODEL=gpt-4.1-mini

# Optional governance / guardrails
NAUTORUS_GOVERNANCE_ENABLED=true
NAUTORUS_GOVERNANCE_ALLOW_WEB_SEARCH=false
NAUTORUS_GOVERNANCE_LOG_ONLY=false
NAUTORUS_HALLUCINATION_GUARDRAILS_ENABLED=true
# Personalization default for retrieval memory scope: session or global
NAUTORUS_PERSONALIZATION_DEFAULT_MEMORY_SCOPE=global

# Optional CLI session name
NAUTORUS_CLI_SESSION_ID=nautorus-cli
