# Manual eval overlay source-index configuration.
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_PATH ?= $(OVERLAY_SOURCE_INDEX_PATH)
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_PATH ?= $(DRAFT_PATH)
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_FORCE ?= $(FORCE)

MANUAL_EVALS_OVERLAY_COMPARISON_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_OVERLAY_COMPARISON_ARGS += $(if $(strip $(MANUAL_EVALS_OVERLAY_SOURCE_INDEX_PATH)),--overlay-source-index "$(MANUAL_EVALS_OVERLAY_SOURCE_INDEX_PATH)")
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_ARGS += $(if $(strip $(MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_PATH)),--output-path "$(MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_PATH)")
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_ARGS += $(if $(filter 1 yes true,$(MANUAL_EVALS_OVERLAY_SOURCE_INDEX_DRAFT_FORCE)),--force)
MANUAL_EVALS_OVERLAY_SOURCE_INDEX_VALIDATE_ARGS = $(MANUAL_EVALS_OVERLAY_COMPARISON_ARGS)
