# Manual eval feedback decision and reclassify configuration.
MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_PATH ?= $(DRAFT_PATH)
MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_FORCE ?= $(FORCE)
MANUAL_EVALS_FEEDBACK_DECISION_PATH ?= $(DECISION_PATH)
MANUAL_EVALS_FEEDBACK_RECLASSIFY_PLAN_PATH ?= $(PLAN_PATH)
MANUAL_EVALS_RECLASSIFY_CONFIRM ?= $(CONFIRM)
MANUAL_EVALS_RECLASSIFY_BACKUP_ROOT ?= $(BACKUP_ROOT)

MANUAL_EVALS_FEEDBACK_DECISION_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_FEEDBACK_DECISION_ARGS += $(if $(strip $(MANUAL_EVALS_FEEDBACK_DECISION_PATH)),--decision-path "$(MANUAL_EVALS_FEEDBACK_DECISION_PATH)")
MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_ARGS += $(if $(strip $(MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_PATH)),--output-path "$(MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_PATH)")
MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_ARGS += $(if $(filter 1 yes true,$(MANUAL_EVALS_FEEDBACK_DECISION_DRAFT_FORCE)),--force)

MANUAL_EVALS_NO_CONTEXT_RECLASSIFY_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_NO_CONTEXT_RECLASSIFY_ARGS += $(if $(strip $(MANUAL_EVALS_RECLASSIFY_CONFIRM)),--confirm "$(MANUAL_EVALS_RECLASSIFY_CONFIRM)")
MANUAL_EVALS_NO_CONTEXT_RECLASSIFY_ARGS += $(if $(strip $(MANUAL_EVALS_RECLASSIFY_BACKUP_ROOT)),--backup-root "$(MANUAL_EVALS_RECLASSIFY_BACKUP_ROOT)")
MANUAL_EVALS_FEEDBACK_RECLASSIFY_ARGS = $(if $(strip $(MANUAL_EVALS_FEEDBACK_RECLASSIFY_PLAN_PATH)),--plan-path "$(MANUAL_EVALS_FEEDBACK_RECLASSIFY_PLAN_PATH)")
MANUAL_EVALS_FEEDBACK_RECLASSIFY_APPLY_ARGS = $(MANUAL_EVALS_FEEDBACK_RECLASSIFY_ARGS)
MANUAL_EVALS_FEEDBACK_RECLASSIFY_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_RECLASSIFY_CONFIRM)),--confirm "$(MANUAL_EVALS_RECLASSIFY_CONFIRM)")
MANUAL_EVALS_FEEDBACK_RECLASSIFY_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_RECLASSIFY_BACKUP_ROOT)),--backup-root "$(MANUAL_EVALS_RECLASSIFY_BACKUP_ROOT)")
