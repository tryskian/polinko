# Manual eval OCR retry execution arguments.
MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR ?= $(EXECUTION_DIR)
MANUAL_EVALS_OCR_RETRY_RUN_DIR ?= $(RUN_DIR)
MANUAL_EVALS_OCR_RETRY_PROVIDER ?= $(OCR_PROVIDER)
MANUAL_EVALS_OCR_RETRY_MODEL ?= $(OCR_MODEL)

MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS = $(MANUAL_EVALS_OCR_RETRY_PLAN_ARGS) $(MANUAL_EVALS_OCR_RETRY_SELECTION_VALIDATE_ARGS)
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR)),--execution-dir "$(MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_PROVIDER)),--ocr-provider "$(MANUAL_EVALS_OCR_RETRY_PROVIDER)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_MODEL)),--ocr-model "$(MANUAL_EVALS_OCR_RETRY_MODEL)")
MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_RUN_DIR)),--run-dir "$(MANUAL_EVALS_OCR_RETRY_RUN_DIR)")
