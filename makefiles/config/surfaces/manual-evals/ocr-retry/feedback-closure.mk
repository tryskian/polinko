# Manual eval OCR retry feedback closure arguments.
MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT ?= $(BACKUP_ROOT)
MANUAL_EVALS_OCR_RETRY_BACKUP_DIR ?= $(BACKUP_DIR)
MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT ?= $(RESTORE_ROOT)

MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_PREVIEW_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT)),--backup-root "$(MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_REPORT_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_BACKUP_DIR)),--backup-dir "$(MANUAL_EVALS_OCR_RETRY_BACKUP_DIR)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS = $(MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT)),--restore-root "$(MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT)")
