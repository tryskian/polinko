# Server daemon configuration.
SERVER_REPO_SLUG ?= $(notdir $(CURDIR))
SERVER_RUNTIME_ROOT ?= /tmp/polinko-runtime
SERVER_STATE_DIR ?= $(SERVER_RUNTIME_ROOT)/$(SERVER_REPO_SLUG)
SERVER_PID_FILE ?= $(SERVER_STATE_DIR)/server.pid
SERVER_LOG ?= $(SERVER_STATE_DIR)/server.log
SERVER_LAUNCHER_PYTHON ?= $(PYTHON)
SERVER_DAEMON_SCRIPT ?= ./tools/run_server_daemon.sh
SERVER_DAEMON_ENV = \
	PYTHON="$(PYTHON)" \
	SERVER_LAUNCHER_PYTHON="$(SERVER_LAUNCHER_PYTHON)" \
	ASGI_APP="$(ASGI_APP)" \
	DEV_HOST="$(DEV_HOST)" \
	DEV_BACKEND_PORT="$(DEV_BACKEND_PORT)" \
	SERVER_REPO_SLUG="$(SERVER_REPO_SLUG)" \
	SERVER_RUNTIME_ROOT="$(SERVER_RUNTIME_ROOT)" \
	SERVER_STATE_DIR="$(SERVER_STATE_DIR)" \
	SERVER_PID_FILE="$(SERVER_PID_FILE)" \
	SERVER_LOG="$(SERVER_LOG)"
