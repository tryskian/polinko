# Notebook, portfolio, mockup, and local browser surface configuration.
DEV_PORTFOLIO_URL ?= http://$(DEV_HOST):$(DEV_BACKEND_PORT)/portfolio
# Legacy compatibility only: prefer PORTFOLIO_APP_DIR for new usage.
ifneq ($(origin FRONTEND_DIR), undefined)
PORTFOLIO_APP_DIR ?= $(FRONTEND_DIR)
else
PORTFOLIO_APP_DIR ?= apps/portfolio
endif
FRONTEND_DIR ?= $(PORTFOLIO_APP_DIR)
PORTFOLIO_STATIC_DIR ?= public/portfolio
PORTFOLIO_MOCKUP_DIR ?= docs/peanut/assets/portfolio-mockups
PORTFOLIO_MOCKUP_PORT ?= 8765
PORTFOLIO_MOCKUP_URL ?= http://127.0.0.1:$(PORTFOLIO_MOCKUP_PORT)/landing-mockups.html
PORTFOLIO_LAUNCH ?= none
PORTFOLIO_PLAYWRIGHT_SESSION ?= $(PLAYWRIGHT_SESSION)
NOTEBOOK_DIR ?= .local/notebooks
NOTEBOOK_START_PATH ?= $(NOTEBOOK_DIR)/ocr-eval-live-filters-starter.ipynb
NOTEBOOK_START_PATH_ABS := $(abspath $(NOTEBOOK_START_PATH))
NOTEBOOK_DIR_ABS := $(abspath $(NOTEBOOK_DIR))
MANUAL_EVALS_FEEDBACK_OUTCOME ?= $(OUTCOME)
MANUAL_EVALS_FEEDBACK_COHORT ?= $(COHORT)
MANUAL_EVALS_FEEDBACK_LIMIT ?= $(LIMIT)
MANUAL_EVALS_OCR_RETRY_ARTIFACT_IDS ?= $(ARTIFACT_IDS)
MANUAL_EVALS_OCR_RETRY_SELECTION_PATH ?= $(SELECTION_PATH)
MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_PATH ?= $(DRAFT_PATH)
MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_FORCE ?= $(FORCE)
MANUAL_EVALS_OCR_RETRY_CONFIRM ?= $(CONFIRM)
MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR ?= $(EXECUTION_DIR)
MANUAL_EVALS_OCR_RETRY_RUN_DIR ?= $(RUN_DIR)
MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT ?= $(BACKUP_ROOT)
MANUAL_EVALS_OCR_RETRY_BACKUP_DIR ?= $(BACKUP_DIR)
MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT ?= $(RESTORE_ROOT)
MANUAL_EVALS_OCR_RETRY_PROVIDER ?= $(OCR_PROVIDER)
MANUAL_EVALS_OCR_RETRY_MODEL ?= $(OCR_MODEL)
MANUAL_EVALS_FEEDBACK_FILTER_ARGS = $(if $(strip $(MANUAL_EVALS_FEEDBACK_OUTCOME)),--outcome "$(MANUAL_EVALS_FEEDBACK_OUTCOME)")
MANUAL_EVALS_FEEDBACK_FILTER_ARGS += $(if $(strip $(MANUAL_EVALS_FEEDBACK_COHORT)),--cohort "$(MANUAL_EVALS_FEEDBACK_COHORT)")
MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS = $(MANUAL_EVALS_FEEDBACK_FILTER_ARGS)
MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS += $(if $(strip $(MANUAL_EVALS_FEEDBACK_LIMIT)),--limit "$(MANUAL_EVALS_FEEDBACK_LIMIT)")
MANUAL_EVALS_OCR_RETRY_PLAN_ARGS = $(MANUAL_EVALS_FEEDBACK_ACTIONABLE_ARGS)
MANUAL_EVALS_OCR_RETRY_PLAN_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_ARTIFACT_IDS)),--artifact-id "$(MANUAL_EVALS_OCR_RETRY_ARTIFACT_IDS)")
MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_PATH)),--output-path "$(MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_PATH)")
MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_ARGS += $(if $(filter 1 yes true,$(MANUAL_EVALS_OCR_RETRY_SELECTION_DRAFT_FORCE)),--force)
MANUAL_EVALS_OCR_RETRY_SELECTION_VALIDATE_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_SELECTION_PATH)),--selection-path "$(MANUAL_EVALS_OCR_RETRY_SELECTION_PATH)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS = $(MANUAL_EVALS_OCR_RETRY_PLAN_ARGS) $(MANUAL_EVALS_OCR_RETRY_SELECTION_VALIDATE_ARGS)
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR)),--execution-dir "$(MANUAL_EVALS_OCR_RETRY_EXECUTION_DIR)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_PROVIDER)),--ocr-provider "$(MANUAL_EVALS_OCR_RETRY_PROVIDER)")
MANUAL_EVALS_OCR_RETRY_EXECUTE_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_MODEL)),--ocr-model "$(MANUAL_EVALS_OCR_RETRY_MODEL)")
MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_RUN_DIR)),--run-dir "$(MANUAL_EVALS_OCR_RETRY_RUN_DIR)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_PREVIEW_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT)),--backup-root "$(MANUAL_EVALS_OCR_RETRY_BACKUP_ROOT)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_APPLY_REPORT_ARGS = $(MANUAL_EVALS_OCR_RETRY_EXECUTION_REPORT_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_ARGS = $(if $(strip $(MANUAL_EVALS_OCR_RETRY_BACKUP_DIR)),--backup-dir "$(MANUAL_EVALS_OCR_RETRY_BACKUP_DIR)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS = $(MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_ARGS)
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_CONFIRM)),--confirm "$(MANUAL_EVALS_OCR_RETRY_CONFIRM)")
MANUAL_EVALS_OCR_RETRY_FEEDBACK_CLOSURE_RESTORE_APPLY_ARGS += $(if $(strip $(MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT)),--restore-root "$(MANUAL_EVALS_OCR_RETRY_RESTORE_ROOT)")
PORTFOLIO_MOCKUP_PID_FILE ?= /tmp/polinko-portfolio-mockups.pid
PORTFOLIO_MOCKUP_LOG ?= /tmp/polinko-portfolio-mockups.log
PLAYWRIGHT_SNAPSHOT_BASE_DIR ?= docs/peanut/assets/screenshots/playwright
PLAYWRIGHT_SNAPSHOT_DAY ?= $(shell date +%d-%m-%y)
PLAYWRIGHT_SESSION ?= polinko
PWCLI_TOOL ?= tools/pwcli_daily.sh
