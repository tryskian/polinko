# Local eval gate runner configuration.
LOCAL_EVAL_GATE_RUNNER_SCRIPT ?= ./tools/run_local_eval_gate.sh
LOCAL_EVAL_GATE_RUNNER_ENV = \
	PYTHON="$(PYTHON)" \
	ASGI_APP="$(ASGI_APP)" \
	SMOKE_PORT="$(SMOKE_PORT)" \
	SMOKE_BASE_URL="$(SMOKE_BASE_URL)" \
	SMOKE_HISTORY_DB="$(SMOKE_HISTORY_DB)" \
	SMOKE_MEMORY_DB="$(SMOKE_MEMORY_DB)" \
	SMOKE_VECTOR_DB="$(SMOKE_VECTOR_DB)" \
	GATE_PORT="$(GATE_PORT)" \
	GATE_BASE_URL="$(GATE_BASE_URL)" \
	GATE_SESSION_DB="$(GATE_SESSION_DB)" \
	GATE_VECTOR_DB="$(GATE_VECTOR_DB)" \
	GATE_VECTOR_EMBEDDING_PROVIDER="$(GATE_VECTOR_EMBEDDING_PROVIDER)" \
	RETRIEVAL_REQUEST_RETRIES="$(RETRIEVAL_REQUEST_RETRIES)" \
	RETRIEVAL_REQUEST_RETRY_DELAY_MS="$(RETRIEVAL_REQUEST_RETRY_DELAY_MS)" \
	RETRIEVAL_CHAT_HARNESS_MODE="$(RETRIEVAL_CHAT_HARNESS_MODE)" \
	OCR_EVAL_TIMEOUT="$(OCR_EVAL_TIMEOUT)" \
	OCR_EVAL_OCR_RETRIES="$(OCR_EVAL_OCR_RETRIES)" \
	OCR_EVAL_OCR_RETRY_DELAY_MS="$(OCR_EVAL_OCR_RETRY_DELAY_MS)" \
	OCR_MAX_CONSEC_RATE_LIMIT_ERRORS="$(OCR_MAX_CONSEC_RATE_LIMIT_ERRORS)" \
	STYLE_CASE_ATTEMPTS="$(STYLE_CASE_ATTEMPTS)" \
	STYLE_MIN_PASS_ATTEMPTS="$(STYLE_MIN_PASS_ATTEMPTS)" \
	STYLE_EVAL_MODE="$(STYLE_EVAL_MODE)" \
	STYLE_CHAT_HARNESS_MODE="$(STYLE_CHAT_HARNESS_MODE)" \
	RESPONSE_BEHAVIOUR_CHAT_HARNESS_MODE="$(RESPONSE_BEHAVIOUR_CHAT_HARNESS_MODE)" \
	HALLUCINATION_EVAL_MODE="$(HALLUCINATION_EVAL_MODE)" \
	HALLUCINATION_JUDGE_MODEL="$(HALLUCINATION_JUDGE_MODEL)" \
	HALLUCINATION_JUDGE_API_KEY_ENV="$(HALLUCINATION_JUDGE_API_KEY_ENV)" \
	HALLUCINATION_JUDGE_BASE_URL="$(HALLUCINATION_JUDGE_BASE_URL)" \
	HALLUCINATION_MIN_ACCEPTABLE_SCORE="$(HALLUCINATION_MIN_ACCEPTABLE_SCORE)" \
	HALLUCINATION_CHAT_HARNESS_MODE="$(HALLUCINATION_CHAT_HARNESS_MODE)"
