# Eval report and OCR report configuration.
EVAL_REPORT_RUNNER_SCRIPT ?= ./tools/run_eval_report.sh
EVAL_REPORT_RUNNER_ENV = \
	PYTHON="$(PYTHON)" \
	RETRIEVAL_REQUEST_RETRIES="$(RETRIEVAL_REQUEST_RETRIES)" \
	RETRIEVAL_REQUEST_RETRY_DELAY_MS="$(RETRIEVAL_REQUEST_RETRY_DELAY_MS)" \
	HALLUCINATION_MIN_ACCEPTABLE_SCORE="$(HALLUCINATION_MIN_ACCEPTABLE_SCORE)" \
	STYLE_CASE_ATTEMPTS="$(STYLE_CASE_ATTEMPTS)" \
	STYLE_MIN_PASS_ATTEMPTS="$(STYLE_MIN_PASS_ATTEMPTS)" \
	OCR_SAFETY_CASES="$(OCR_SAFETY_CASES)" \
	OCR_EVAL_TIMEOUT="$(OCR_EVAL_TIMEOUT)" \
	OCR_EVAL_OCR_RETRIES="$(OCR_EVAL_OCR_RETRIES)" \
	OCR_EVAL_OCR_RETRY_DELAY_MS="$(OCR_EVAL_OCR_RETRY_DELAY_MS)" \
	OCR_MAX_CONSEC_RATE_LIMIT_ERRORS="$(OCR_MAX_CONSEC_RATE_LIMIT_ERRORS)" \
	CLIP_AB_SOURCE_TYPES="$(CLIP_AB_SOURCE_TYPES)"
EVAL_REPORTS_PARALLEL_RUNNER_SCRIPT ?= ./tools/run_eval_reports_parallel.sh
EVAL_REPORTS_PARALLEL_RUNNER_ENV = \
	PYTHON="$(PYTHON)" \
	BASE_URL="$(BASE_URL)" \
	HALLUCINATION_EVAL_MODE="$(HALLUCINATION_EVAL_MODE)" \
	HALLUCINATION_MIN_ACCEPTABLE_SCORE="$(HALLUCINATION_MIN_ACCEPTABLE_SCORE)"

OCR_REPORT_BUILDER_SCRIPT ?= ./tools/run_ocr_report_builder.sh
OCR_REPORT_BUILDER_ENV = \
	PYTHON="$(PYTHON)" \
	OCR_TRANSCRIPT_CASES_GROWTH="$(OCR_TRANSCRIPT_CASES_GROWTH)" \
	OCR_TRANSCRIPT_REVIEW="$(OCR_TRANSCRIPT_REVIEW)" \
	OCR_GROWTH_STABILITY_OUTPUT="$(OCR_GROWTH_STABILITY_OUTPUT)" \
	OCR_GROWTH_STABILITY_REPORT_DIR="$(OCR_GROWTH_STABILITY_REPORT_DIR)" \
	OCR_GROWTH_METRICS_OUTPUT="$(OCR_GROWTH_METRICS_OUTPUT)" \
	OCR_GROWTH_METRICS_MARKDOWN="$(OCR_GROWTH_METRICS_MARKDOWN)" \
	OCR_GROWTH_LIMIT_RUNS="$(OCR_GROWTH_LIMIT_RUNS)" \
	OCR_GROWTH_FAIL_COHORT_JSON="$(OCR_GROWTH_FAIL_COHORT_JSON)" \
	OCR_GROWTH_FAIL_COHORT_MARKDOWN="$(OCR_GROWTH_FAIL_COHORT_MARKDOWN)" \
	OCR_FAIL_COHORT_MIN_RUNS="$(OCR_FAIL_COHORT_MIN_RUNS)" \
	OCR_FAIL_COHORT_INCLUDE_UNSTABLE="$(OCR_FAIL_COHORT_INCLUDE_UNSTABLE)" \
	OCR_FAIL_COHORT_REQUIRE_OCR_FRAMING="$(OCR_FAIL_COHORT_REQUIRE_OCR_FRAMING)" \
	OCR_FAIL_COHORT_INCLUDE_EXPLORATORY="$(OCR_FAIL_COHORT_INCLUDE_EXPLORATORY)" \
	OCR_FAIL_COHORT_EXPLORATORY_MAX_CASES="$(OCR_FAIL_COHORT_EXPLORATORY_MAX_CASES)" \
	OCR_FOCUS_CASES_JSON="$(OCR_FOCUS_CASES_JSON)" \
	OCR_FOCUS_MAX_CASES="$(OCR_FOCUS_MAX_CASES)" \
	OCR_FOCUS_INCLUDE_FAIL_HISTORY="$(OCR_FOCUS_INCLUDE_FAIL_HISTORY)" \
	OCR_FOCUS_INCLUDE_EXPLORATORY="$(OCR_FOCUS_INCLUDE_EXPLORATORY)" \
	OCR_FOCUS_OUTPUT="$(OCR_FOCUS_OUTPUT)" \
	OCR_FOCUS_FAIL_PATTERNS_JSON="$(OCR_FOCUS_FAIL_PATTERNS_JSON)" \
	OCR_FOCUS_FAIL_PATTERNS_MD="$(OCR_FOCUS_FAIL_PATTERNS_MD)"
OCR_REPORT_WORKFLOW_SCRIPT ?= ./tools/run_ocr_report_workflow.sh
OCR_REPORT_WORKFLOW_ENV = \
	$(OCR_REPORT_BUILDER_ENV) \
	OCR_REPORT_BUILDER_SCRIPT="$(OCR_REPORT_BUILDER_SCRIPT)"
OCR_LANE_INVENTORY_SCRIPT ?= ./tools/report_ocr_lane_inventory.py
OCR_LANE_INVENTORY_ARGS ?= $(ARGS)
OCR_LANE_INVENTORY_FRESHNESS_DAYS ?= $(FRESHNESS_DAYS)
