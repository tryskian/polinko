	OCR_GROWTH_OCR_RETRY_DELAY_MS="$(OCR_GROWTH_OCR_RETRY_DELAY_MS)" \
	OCR_GROWTH_BATCH_REPORT_DIR="$(OCR_GROWTH_BATCH_REPORT_DIR)" \
	OCR_GROWTH_BATCH_SUMMARY_JSON="$(OCR_GROWTH_BATCH_SUMMARY_JSON)" \
