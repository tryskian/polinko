# OCR report builder configuration.
OCR_REPORT_BUILDER_SCRIPT ?= ./tools/run_ocr_report_builder.sh
OCR_REPORT_BUILDER_ENV = \
	PYTHON="$(PYTHON)" \
	OCR_TRANSCRIPT_CASES_GROWTH="$(OCR_TRANSCRIPT_CASES_GROWTH)" \
	OCR_TRANSCRIPT_REVIEW="$(OCR_TRANSCRIPT_REVIEW)" \
	OCR_GROWTH_STABILITY_OUTPUT="$(OCR_GROWTH_STABILITY_OUTPUT)" \
	OCR_GROWTH_STABILITY_REPORT_DIR="$(OCR_GROWTH_STABILITY_REPORT_DIR)" \
	OCR_GROWTH_METRICS_OUTPUT="$(OCR_GROWTH_METRICS_OUTPUT)" \
	OCR_GROWTH_METRICS_MARKDOWN="$(OCR_GROWTH_METRICS_MARKDOWN)" \
	OCR_GROWTH_LIMIT_RUNS="$(OCR_GROWTH_LIMIT_RUNS)" \
	OCR_GROWTH_FAIL_COHORT_JSON="$(OCR_GROWTH_FAIL_COHORT_JSON)" \
	OCR_GROWTH_FAIL_COHORT_MARKDOWN="$(OCR_GROWTH_FAIL_COHORT_MARKDOWN)" \
