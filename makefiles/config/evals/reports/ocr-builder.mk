	OCR_FOCUS_CASES_JSON="$(OCR_FOCUS_CASES_JSON)" \
	OCR_FOCUS_MAX_CASES="$(OCR_FOCUS_MAX_CASES)" \
	OCR_FOCUS_INCLUDE_FAIL_HISTORY="$(OCR_FOCUS_INCLUDE_FAIL_HISTORY)" \
	OCR_FOCUS_INCLUDE_EXPLORATORY="$(OCR_FOCUS_INCLUDE_EXPLORATORY)" \
	OCR_FOCUS_OUTPUT="$(OCR_FOCUS_OUTPUT)" \
	OCR_FOCUS_FAIL_PATTERNS_JSON="$(OCR_FOCUS_FAIL_PATTERNS_JSON)" \
	OCR_FOCUS_FAIL_PATTERNS_MD="$(OCR_FOCUS_FAIL_PATTERNS_MD)"
