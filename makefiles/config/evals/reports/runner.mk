	OCR_EVAL_OCR_RETRY_DELAY_MS="$(OCR_EVAL_OCR_RETRY_DELAY_MS)" \
	OCR_MAX_CONSEC_RATE_LIMIT_ERRORS="$(OCR_MAX_CONSEC_RATE_LIMIT_ERRORS)" \
