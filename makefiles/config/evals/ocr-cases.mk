	OCR_GENERALIZATION_REVIEW_MAX_PER_CONVERSATION="$(OCR_GENERALIZATION_REVIEW_MAX_PER_CONVERSATION)" \
	OCR_GENERALIZATION_REVIEW_INCLUDE_IDS="$(OCR_GENERALIZATION_REVIEW_INCLUDE_IDS)" \
	OCR_GROWTH_MAX_CASES="$(OCR_GROWTH_MAX_CASES)" \
	OCR_HANDWRITING_BENCHMARK_TOP_K="$(OCR_HANDWRITING_BENCHMARK_TOP_K)" \
