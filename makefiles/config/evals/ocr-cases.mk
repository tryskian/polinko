	CGPT_EXPORT_ROOT="$(CGPT_EXPORT_ROOT)" \
	CGPT_EXPORT_ROOT_DEFAULT="$(CGPT_EXPORT_ROOT_DEFAULT)" \
	CGPT_EXPORT_OUTPUT_DIR="$(CGPT_EXPORT_OUTPUT_DIR)" \
