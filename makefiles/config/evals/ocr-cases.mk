	OCR_TRANSCRIPT_CASES_ILLUSTRATION="$(OCR_TRANSCRIPT_CASES_ILLUSTRATION)" \
	OCR_TRANSCRIPT_CASES_HANDWRITING_BENCHMARK="$(OCR_TRANSCRIPT_CASES_HANDWRITING_BENCHMARK)" \
	OCR_TRANSCRIPT_CASES_TYPED_BENCHMARK="$(OCR_TRANSCRIPT_CASES_TYPED_BENCHMARK)" \
	OCR_TRANSCRIPT_CASES_ILLUSTRATION_BENCHMARK="$(OCR_TRANSCRIPT_CASES_ILLUSTRATION_BENCHMARK)" \
