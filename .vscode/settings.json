{
	"python.defaultInterpreterPath": "${workspaceFolder}/polinko-repositioning-system/bin/python",
	"python.terminal.activateEnvironment": true,
	"terminal.integrated.accessibleViewPreserveCursorPosition": true,
	"terminal.integrated.allowMnemonics": true,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.cursorStyleInactive": "underline",
	"terminal.integrated.defaultLocation": "panel",
	"terminal.integrated.fontSize": 12,
	"terminal.integrated.lineHeight": 1.25,
	"editor.formatOnPaste": true,
	"editor.formatOnType": true,
	"workbench.editor.wrapTabs": false,
	"editor.wordWrap": "on",
	"chat.editor.wordWrap": "on",
	"terminal.explorerKind": "external",
	"diffEditor.wordWrap": "on",
	"notebook.output.wordWrap": true,
	"editor.wrapOnEscapedLineFeeds": true
}
