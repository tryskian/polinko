{
	"python.defaultInterpreterPath": "${workspaceFolder}/polinko-repositioning-system/bin/python",
	"python.terminal.activateEnvironment": true,
	"terminal.integrated.accessibleViewPreserveCursorPosition": true,
	"terminal.integrated.allowMnemonics": true,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.cursorStyleInactive": "underline",
	"terminal.integrated.defaultLocation": "panel",
	"terminal.integrated.fontSize": 12,
	"terminal.integrated.lineHeight": 1.25,
	"editor.formatOnPaste": true,
	"editor.formatOnType": true,
	"workbench.editor.wrapTabs": true,
	"editor.wordWrap": "on",
	"chat.editor.wordWrap": "on",
	"terminal.explorerKind": "external",
	"diffEditor.wordWrap": "on",
	"notebook.output.wordWrap": true,
	"editor.wrapOnEscapedLineFeeds": true,
	"window.autoDetectColorScheme": true,
	"workbench.editor.centeredLayoutFixedWidth": true,
	"workbench.editor.closeOnFileDelete": true,
	"workbench.editor.empty.hint": "hidden",
	"workbench.editor.enablePreviewFromQuickOpen": true,
	"workbench.editor.enablePreviewFromCodeNavigation": true,
	"workbench.editor.revealIfOpen": true,
	"workbench.settings.alwaysShowAdvancedSettings": false,
	"workbench.settings.openDefaultKeybindings": true,
	"workbench.settings.openDefaultSettings": true,
	"workbench.settings.showAISearchToggle": false,
	"editor.find.findOnType": false,
	"editor.find.loop": false,
	"editor.formatOnSave": true,
	"editor.minimap.autohide": "scroll",
	"workbench.commandPalette.experimental.suggestCommands": true,
	"workbench.commandPalette.showAskInChat": false,
	"terminal.integrated.macOptionClickForcesSelection": true,
	"terminal.integrated.rightClickBehavior": "copyPaste",
	"terminal.integrated.shellIntegration.enabled": false,
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.suggest.cdPath": "relative",
	"terminal.integrated.tabs.defaultColor": null,
	"terminal.integrated.tabs.location": "left",
	"terminal.integrated.tabs.showActiveTerminal": "always"
}
